# ═══════════════════════════════════════════════════════════════
# FusionVerse — Hostinger .htaccess
# Optimized for 600+ concurrent users — reduces MySQL connection
# pressure and speeds up PHP script execution.
# ═══════════════════════════════════════════════════════════════

# ── PHP Performance Settings (Hostinger supports php_value) ──
# Shorter max_execution_time means PHP workers are freed faster,
# which in turn releases DB connections back to the pool quicker.
php_value max_execution_time 30
php_value max_input_time 30
php_value memory_limit 128M

# Disable PHP output buffering at the Apache level (we handle it
# in header.php with gzip ob_start already).
php_flag output_buffering Off

# ── Security: hide PHP version to prevent fingerprinting ──────
php_flag expose_php Off

# ── Disable directory listing ─────────────────────────────────
Options -Indexes

# ── Caching static assets (reduces repeat requests, frees server) ─
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png            "access plus 30 days"
    ExpiresByType image/jpg            "access plus 30 days"
    ExpiresByType image/jpeg           "access plus 30 days"
    ExpiresByType image/gif            "access plus 30 days"
    ExpiresByType image/webp           "access plus 30 days"
    ExpiresByType image/svg+xml        "access plus 30 days"
    ExpiresByType font/woff2           "access plus 30 days"
</IfModule>

# ── Gzip Compression (reduces bandwidth = faster responses) ───
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

# ── Prevent access to sensitive files ─────────────────────────
<FilesMatch "\.(env|log|sql|sh|git|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block direct access to config directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^scratch/ - [F,L]
    RewriteRule ^includes/ - [F,L]
</IfModule>
